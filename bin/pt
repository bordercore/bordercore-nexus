#!/bin/bash
# Short pytest wrapper that excludes data_quality and functional tests
# Usage: pt [-b] [-d] [-f] <test_substring>
#   -b: allow database access (do not use -p no:django)
#   -d: exclude data_quality tests
#   -f: exclude functional tests
#   If no options are passed, runs with -p no:django (no DB) for speed
# Example: pt test_get_cover_info
# Example: pt -b test_blob_metadata_exists_in_elasticsearch  # with DB

# Get the directory where this script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
VENV_PATH="$PROJECT_DIR/.venv/bin/activate"

if [ -f "$VENV_PATH" ]; then
    source "$VENV_PATH"
fi

EXCLUDE_DATA_QUALITY=false
EXCLUDE_FUNCTIONAL=false
INCLUDE_DB=false

while getopts "bdf" opt; do
    case $opt in
        b)
            INCLUDE_DB=true
            ;;
        d)
            EXCLUDE_DATA_QUALITY=true
            ;;
        f)
            EXCLUDE_FUNCTIONAL=true
            ;;
        \?)
            echo "Usage: $0 [-b] [-d] [-f] <test_substring>"
            echo "  -b: allow database access (required for tests that use django_db)"
            echo "  -d: exclude data_quality tests"
            echo "  -f: exclude functional tests"
            exit 1
            ;;
    esac
done

shift $((OPTIND - 1))

if [ $# -eq 0 ]; then
    echo "Usage: $0 [-b] [-d] [-f] <test_substring>"
    echo "  -b: allow database access (required for tests that use django_db)"
    echo "  -d: exclude data_quality tests"
    echo "  -f: exclude functional tests"
    echo "Example: $0 test_get_cover_info"
    echo "Example: $0 -b test_blob_metadata_exists_in_elasticsearch"
    exit 1
fi

# When not including DB, disable django plugin for faster runs (avoids "Database access not allowed")
if [ "$INCLUDE_DB" = true ]; then
    NO_DJANGO_OPTS=()
else
    NO_DJANGO_OPTS=(-p no:django -o addopts=)
fi

# Build the marker expression and run pytest
if [ "$EXCLUDE_DATA_QUALITY" = true ] && [ "$EXCLUDE_FUNCTIONAL" = true ]; then
    # Both flags passed: exclude both
    MARKER_EXPR="not data_quality and not functional"
    uv run pytest "${NO_DJANGO_OPTS[@]}" -m "$MARKER_EXPR" "$PROJECT_DIR/bordercore/" -k "$1"
elif [ "$EXCLUDE_DATA_QUALITY" = true ]; then
    # Only -d: exclude data_quality only
    uv run pytest "${NO_DJANGO_OPTS[@]}" -m "not data_quality" "$PROJECT_DIR/bordercore/" -k "$1"
elif [ "$EXCLUDE_FUNCTIONAL" = true ]; then
    # Only -f: exclude functional only
    uv run pytest "${NO_DJANGO_OPTS[@]}" -m "not functional" "$PROJECT_DIR/bordercore/" -k "$1"
else
    # No flags: don't exclude any markers
    uv run pytest "${NO_DJANGO_OPTS[@]}" "$PROJECT_DIR/bordercore/" -k "$1"
fi

